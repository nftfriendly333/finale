<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SWORD — Battle Arena</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400;600;700&family=IM+Fell+English:ital@0;1&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #c9a84c;
    --gold-light: #f0d080;
    --gold-dark: #7a5c1e;
    --blood: #8b1a1a;
    --blood-bright: #d42020;
    --dark0: #0a0a0f;
    --dark1: #10101a;
    --dark2: #16162a;
    --dark3: #1e1e35;
    --dark4: #252540;
    --text-muted: #7070a0;
    --text-body: #c8c8e0;
    --success: #3ecf6e;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--dark0); color: var(--text-body);
    font-family: 'IM Fell English', Georgia, serif;
    min-height: 100vh; display: flex; align-items: center;
    justify-content: center; overflow-x: hidden;
  }
  #stars { position: fixed; top:0; left:0; width:100%; height:100%; pointer-events:none; z-index:0; }
  .star { position:absolute; background:#fff; border-radius:50%; animation: twinkle var(--d,3s) infinite alternate; }
  @keyframes twinkle { from{opacity:0.1} to{opacity:0.9} }

  .card {
    position:relative; z-index:1; width:100%; max-width:500px;
    margin:2rem 1.25rem; background:var(--dark1);
    border:1px solid var(--gold-dark); border-radius:8px;
    padding:2.5rem 2rem; text-align:center;
  }
  .eyebrow { font-family:'Cinzel',serif; font-size:10px; letter-spacing:0.35em; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.6rem; }
  .site-title { font-family:'Cinzel Decorative',serif; font-size:clamp(2.4rem,8vw,3.6rem); font-weight:900; color:var(--gold-light); text-shadow:0 0 50px rgba(201,168,76,0.35),0 2px 0 var(--gold-dark); line-height:1.1; margin-bottom:0.4rem; }
  .site-sub { font-family:'Cinzel',serif; font-size:0.72rem; letter-spacing:0.15em; color:var(--text-muted); margin-bottom:1.75rem; }
  .divider { display:flex; align-items:center; gap:0.75rem; margin:1.5rem 0; }
  .divider-line { flex:1; height:1px; background:linear-gradient(90deg,transparent,var(--gold-dark),transparent); }
  .divider-diamond { width:8px; height:8px; background:var(--gold); transform:rotate(45deg); flex-shrink:0; }

  /* Pre-connect */
  .metamask-icon { width:72px; height:72px; margin:0 auto 1.25rem; display:block; }
  .connect-hint { font-size:0.88rem; color:var(--text-muted); margin-bottom:1.75rem; line-height:1.7; font-style:italic; }
  .connect-btn-main {
    display:flex; align-items:center; justify-content:center; gap:0.65rem;
    width:100%; padding:1rem 1.5rem; cursor:pointer;
    font-family:'Cinzel',serif; font-size:0.9rem; font-weight:600;
    letter-spacing:0.1em; text-transform:uppercase;
    background:linear-gradient(180deg,#e8820a 0%,#9a4d00 100%);
    color:#fff; border:1px solid #f09030; border-radius:5px;
    transition:all 0.2s; text-shadow:0 1px 0 rgba(0,0,0,0.4);
  }
  .connect-btn-main:hover:not(:disabled) { background:linear-gradient(180deg,#f09020 0%,#c06000 100%); transform:translateY(-1px); box-shadow:0 4px 20px rgba(230,120,10,0.35); }
  .connect-btn-main:disabled { opacity:0.5; cursor:not-allowed; }
  .no-metamask { display:none; margin-top:1.25rem; font-family:'Cinzel',serif; font-size:0.75rem; letter-spacing:0.08em; color:var(--blood-bright); line-height:1.7; }
  .no-metamask a { color:var(--gold); }

  /* Arena */
  #arena { display:none; }
  .wallet-pill { display:inline-flex; align-items:center; gap:0.5rem; background:var(--dark3); border:1px solid var(--gold-dark); border-radius:20px; padding:0.35rem 0.9rem; font-family:'Cinzel',serif; font-size:0.7rem; letter-spacing:0.08em; color:var(--success); margin-bottom:1.25rem; }
  .wallet-dot-sm { width:7px; height:7px; border-radius:50%; background:var(--success); box-shadow:0 0 5px var(--success); }
  .sword-bal { font-family:'Cinzel Decorative',serif; font-size:1.6rem; color:var(--gold-light); font-weight:700; margin-bottom:0.2rem; }
  .sword-bal-label { font-family:'Cinzel',serif; font-size:0.7rem; letter-spacing:0.2em; color:var(--text-muted); text-transform:uppercase; margin-bottom:1.5rem; }

  .fighters { display:grid; grid-template-columns:1fr 50px 1fr; align-items:center; gap:0.5rem; margin:1.25rem 0; }
  .fighter { text-align:center; }
  .fighter-sprite { font-size:3rem; display:block; margin:0 auto 0.4rem; filter:drop-shadow(0 0 6px rgba(201,168,76,0.25)); }
  .fighter-name { font-family:'Cinzel',serif; font-size:0.65rem; letter-spacing:0.12em; color:var(--gold); text-transform:uppercase; }
  .fighter-sub { font-family:'Cinzel',serif; font-size:0.6rem; color:var(--text-muted); margin-top:3px; }
  .hp-bar { height:5px; background:var(--dark4); border-radius:3px; margin-top:5px; overflow:hidden; }
  .hp-fill { height:100%; border-radius:3px; background:var(--success); transition:width 0.6s ease,background 0.3s; }
  .hp-fill.low { background:var(--blood-bright); }
  .vs-text { font-family:'Cinzel Decorative',serif; font-size:1.2rem; font-weight:900; color:var(--blood-bright); text-shadow:0 0 16px var(--blood); }
  .hoard-label { font-family:'Cinzel',serif; font-size:8px; letter-spacing:0.15em; color:var(--text-muted); text-transform:uppercase; margin-top:6px; }
  .hoard-count { font-family:'Cinzel Decorative',serif; font-size:0.85rem; font-weight:700; color:var(--blood-bright); margin-top:2px; }
  .hoard-count.pulse { animation:hoard-pulse 0.5s ease; }
  @keyframes hoard-pulse { 0%{transform:scale(1)} 40%{transform:scale(1.35)} 100%{transform:scale(1)} }

  .input-row { display:flex; align-items:center; gap:0.75rem; margin:1.25rem 0; }
  .sword-input { flex:1; background:var(--dark3); border:1px solid var(--gold-dark); border-radius:4px; color:var(--gold-light); font-family:'Cinzel Decorative',serif; font-size:1.1rem; padding:0.65rem 0.75rem; text-align:center; outline:none; }
  .sword-input:focus { border-color:var(--gold); }
  .chance-badge { font-family:'Cinzel',serif; font-size:0.68rem; letter-spacing:0.04em; padding:0.35rem 0.7rem; border-radius:3px; font-weight:600; white-space:nowrap; }
  .chance-badge.bad  { background:rgba(139,26,26,0.3); color:#ff7070; border:1px solid var(--blood); }
  .chance-badge.good { background:rgba(62,207,110,0.15); color:var(--success); border:1px solid #2a8a4a; }

  .fight-btn { display:block; width:100%; padding:1rem; font-family:'Cinzel Decorative',serif; font-size:1.05rem; font-weight:700; letter-spacing:0.12em; cursor:pointer; background:linear-gradient(180deg,#9a2020 0%,#5a0e0e 100%); color:var(--gold-light); border:1px solid #c03030; border-radius:4px; transition:all 0.2s; text-shadow:0 1px 0 rgba(0,0,0,0.5); }
  .fight-btn:hover:not(:disabled) { background:linear-gradient(180deg,#c02828 0%,#780f0f 100%); transform:translateY(-1px); box-shadow:0 4px 20px rgba(139,26,26,0.4); }
  .fight-btn:disabled { opacity:0.5; cursor:not-allowed; }

  .log-wrap { margin-top:1.25rem; text-align:left; }
  .log-title { font-family:'Cinzel',serif; font-size:0.68rem; letter-spacing:0.15em; color:var(--text-muted); text-transform:uppercase; margin-bottom:0.5rem; }
  .battle-log { background:var(--dark0); border:1px solid var(--dark4); border-radius:4px; padding:0.75rem; min-height:130px; max-height:180px; overflow-y:auto; font-size:0.82rem; line-height:1.75; }
  .battle-log::-webkit-scrollbar { width:3px; }
  .battle-log::-webkit-scrollbar-thumb { background:var(--gold-dark); border-radius:2px; }
  .log-line { margin:0; padding:1px 0; }
  .log-line.sys  { color:var(--text-muted); font-style:italic; font-size:0.74rem; }
  .log-line.atk  { color:#ff9a9a; }
  .log-line.def  { color:#9ad4ff; }
  .log-line.win  { color:var(--success); font-weight:700; font-family:'Cinzel',serif; }
  .log-line.lose { color:var(--blood-bright); font-weight:700; font-family:'Cinzel',serif; }
  .log-line.gold { color:var(--gold-light); font-family:'Cinzel',serif; }
  .tx-link { display:inline-block; margin-top:3px; font-family:'Cinzel',serif; font-size:0.7rem; color:var(--gold); text-decoration:underline; }

  .result-banner { display:none; text-align:center; padding:1.25rem; border-radius:4px; margin-top:1rem; animation:fadeIn 0.5s ease; }
  @keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:none} }
  .result-banner.victory { display:block; background:rgba(62,207,110,0.1); border:1px solid #2a8a4a; color:var(--success); }
  .result-banner.defeat  { display:block; background:rgba(139,26,26,0.15); border:1px solid var(--blood); color:#ff8080; }
  .result-title { font-family:'Cinzel Decorative',serif; font-size:1.3rem; font-weight:900; margin-bottom:0.4rem; }
  .result-sub   { font-size:0.82rem; opacity:0.85; font-style:italic; }

  @keyframes shake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-7px)} 40%{transform:translateX(7px)} 60%{transform:translateX(-4px)} 80%{transform:translateX(4px)} }
  .shaking { animation:shake 0.4s ease; }
  @keyframes glow-gold { 0%,100%{filter:drop-shadow(0 0 6px rgba(201,168,76,0.2))} 50%{filter:drop-shadow(0 0 20px rgba(201,168,76,0.8))} }
  .glowing { animation:glow-gold 0.6s ease; }

  .disconnect { display:block; margin-top:1.25rem; font-family:'Cinzel',serif; font-size:0.65rem; letter-spacing:0.1em; color:var(--text-muted); cursor:pointer; text-decoration:underline; }
  .disconnect:hover { color:var(--blood-bright); }
  .footer { margin-top:1.75rem; font-family:'Cinzel',serif; font-size:0.6rem; letter-spacing:0.1em; color:var(--dark4); line-height:1.9; }

  @media(max-width:420px) {
    .card { padding:2rem 1.25rem; }
    .fighter-sprite { font-size:2.2rem; }
  }
</style>
</head>
<body>

<div id="stars"></div>

<div class="card">
  <div class="eyebrow">Sepolia Testnet &bull; ERC-20</div>
  <div class="site-title">&#x2694; SWORD</div>
  <div class="site-sub">Token of Champions &bull; Vanquish the Monster</div>
  <div class="divider"><div class="divider-line"></div><div class="divider-diamond"></div><div class="divider-line"></div></div>

  <!-- PRE-CONNECT -->
  <div id="pre-connect">
    <svg class="metamask-icon" viewBox="0 0 318 318" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M274.1 35.5l-99.7 74.1 18.4-43.5 81.3-30.6z" fill="#E2761B" stroke="#E2761B" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M44.4 35.5l98.9 74.7-17.6-44.1-81.3-30.6zM238.3 206.8l-26.5 40.6 56.7 15.6 16.3-55.3-46.5-.9zM33.9 207.7l16.2 55.3 56.7-15.6-26.5-40.6-46.4.9z" fill="#E4761B" stroke="#E4761B" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M103.6 138.2l-15.8 23.9 56.3 2.5-2-60.5-38.5 34.1zM214.9 138.2l-39-34.7-1.3 61.1 56.2-2.5-15.9-23.9zM106.8 247.4l33.8-16.5-29.2-22.8-4.6 39.3zM177.9 230.9l33.9 16.5-4.7-39.3-29.2 22.8z" fill="#E4761B" stroke="#E4761B" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M211.8 247.4l-33.9-16.5 2.7 22.1-.3 9.3 31.5-14.9zM106.8 247.4l31.5 14.9-.2-9.3 2.5-22.1-33.8 16.5z" fill="#D7C1B3" stroke="#D7C1B3" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M138.8 193.5l-28.2-8.3 19.9-9.1 8.3 17.4zM179.7 193.5l8.3-17.4 20 9.1-28.3 8.3z" fill="#233447" stroke="#233447" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M106.8 247.4l4.8-40.6-31.3.9 26.5 39.7zM206 206.8l4.8 40.6 26.5-39.7-31.3-.9zM231.1 162.1l-56.2 2.5 5.2 28.9 8.3-17.4 20 9.1 22.7-23.1zM110.6 185.2l20-9.1 8.2 17.4 5.3-28.9-56.3-2.5 22.8 23.1z" fill="#CD6116" stroke="#CD6116" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M84.3 162.1l23.6 46-.8-22.9-22.8-23.1zM211.4 185.2l-1 22.9 23.7-46-22.7 23.1zM140.6 164.6l-5.3 28.9 6.6 34.1 1.5-44.9-2.8-18.1zM177.9 164.6l-2.7 18 1.3 45 6.7-34.1-5.3-28.9z" fill="#E4751F" stroke="#E4751F" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M183.2 193.5l-6.7 34.1 4.8 3.3 29.2-22.8 1-22.9-28.3 8.3zM110.6 185.2l.8 22.9 29.2 22.8 4.8-3.3-6.6-34.1-28.2-8.3z" fill="#F6851B" stroke="#F6851B" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M183.5 262.3l.3-9.3-2.5-2.2h-37.6l-2.4 2.2.2 9.3-31.5-14.9 11 9 22.3 15.5h38.3l22.4-15.5 11-9-31.5 14.9z" fill="#C0AD9E" stroke="#C0AD9E" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M181.3 230.9l-4.8-3.3h-27.5l-4.8 3.3-2.5 22.1 2.4-2.2h37.6l2.5 2.2-2.9-22.1z" fill="#161616" stroke="#161616" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M278.3 114.2l8.5-40.8-12.7-37.9-96.8 71.8 37.2 31.5 52.6 15.4 11.6-13.5-5-3.6 8-7.3-6.2-4.8 8-6.1-5.2-4.7zM31.8 73.4l8.5 40.8-5.4 4.7 8 6.1-6.1 4.8 8 7.3-5 3.6 11.5 13.5 52.6-15.4 37.2-31.5-96.8-71.8-12.5 37.9z" fill="#763D16" stroke="#763D16" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M267.1 154.2l-52.6-15.4 15.9 23.9-23.7 46 31.2-.4h46.5l-17.3-54.1zM103.6 138.8l-52.6 15.4-17.2 54.1h46.4l31.1.4-23.6-46 15.9-23.9zM177.9 164.6l3.3-57.7 15.2-41.1h-67.5l15 41.1 3.5 57.7 1.2 18.2.1 44.8h27.5l.2-44.8 1.5-18.2z" fill="#F6851B" stroke="#F6851B" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <p class="connect-hint">Connect your MetaMask wallet to enter the Battle Arena.<br>You need SWORD tokens and Sepolia ETH for gas.</p>
    <button class="connect-btn-main" id="connect-btn" onclick="connectWallet()">
      <svg width="18" height="18" viewBox="0 0 318 318" fill="none"><path d="M274.1 35.5l-99.7 74.1 18.4-43.5 81.3-30.6z" fill="#fff" opacity="0.9"/><path d="M44.4 35.5l98.9 74.7-17.6-44.1-81.3-30.6z" fill="#fff" opacity="0.7"/></svg>
      Connect MetaMask
    </button>
    <div class="no-metamask" id="no-metamask">
      MetaMask not detected.<br>
      <a href="https://metamask.io/download/" target="_blank">Install MetaMask</a> then refresh this page.
    </div>
  </div>

  <!-- ARENA -->
  <div id="arena">
    <div class="wallet-pill">
      <div class="wallet-dot-sm"></div>
      <span id="wallet-addr">0x0000...0000</span>
    </div>
    <div class="sword-bal" id="sword-bal">—</div>
    <div class="sword-bal-label">SWORD Balance</div>
    <div class="divider"><div class="divider-line"></div><div class="divider-diamond"></div><div class="divider-line"></div></div>

    <div class="fighters">
      <div class="fighter">
        <span class="fighter-sprite" id="sprite-player">🧝</span>
        <div class="fighter-name">Champion</div>
        <div class="fighter-sub" id="hp-player-text">100 HP</div>
        <div class="hp-bar"><div class="hp-fill" id="hp-player-fill" style="width:100%"></div></div>
      </div>
      <div class="vs-text">VS</div>
      <div class="fighter">
        <span class="fighter-sprite" id="sprite-monster">🐉</span>
        <div class="fighter-name">The Wyrm</div>
        <div class="fighter-sub" id="hp-monster-text">100 HP</div>
        <div class="hp-bar"><div class="hp-fill" id="hp-monster-fill" style="width:100%"></div></div>
        <div class="hoard-label">Swords Collected</div>
        <div class="hoard-count" id="hoard-count">0 ⚔</div>
      </div>
    </div>

    <div class="input-row">
      <input type="number" class="sword-input" id="sword-count" value="100" min="1" placeholder="SWORD amount" />
      <span class="chance-badge good" id="chance-badge">Player wins 98%</span>
    </div>

    <button class="fight-btn" id="fight-btn" onclick="startBattle()">⚔ Enter the Arena</button>

    <div class="log-wrap">
      <div class="log-title">Battle Chronicle</div>
      <div class="battle-log" id="battle-log">
        <p class="log-line sys">— Awaiting challenger... —</p>
      </div>
    </div>

    <div class="result-banner" id="result-banner">
      <div class="result-title" id="result-title"></div>
      <div class="result-sub"   id="result-sub"></div>
    </div>

    <span class="disconnect" onclick="disconnect()">Disconnect wallet</span>
  </div>

  <div class="footer">
    <div>SWORD &bull; 0xe549E983358dbCEC0f85CB59F9b7dCd35f058Ea7</div>
    <div>Sepolia Testnet &bull; For demonstration purposes</div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/6.7.0/ethers.umd.min.js"></script>
<script>
  /* Stars */
  const starEl=document.getElementById('stars');
  for(let i=0;i<140;i++){
    const s=document.createElement('div'); s.className='star';
    const sz=Math.random()*2+0.4;
    s.style.cssText=`left:${Math.random()*100}%;top:${Math.random()*100}%;width:${sz}px;height:${sz}px;--d:${(Math.random()*4+2).toFixed(1)}s;animation-delay:${(Math.random()*6).toFixed(1)}s`;
    starEl.appendChild(s);
  }

  const SWORD_ADDRESS    = '0xe549E983358dbCEC0f85CB59F9b7dCd35f058Ea7';
  const MONSTER_ADDRESS  = '0xe549E983358dbCEC0f85CB59F9b7dCd35f058Ea7';
  const SEPOLIA_CHAIN_ID = '0xaa36a7';
  const ERC20_ABI = [
    'function transfer(address to, uint256 amount) returns (bool)',
    'function balanceOf(address owner) view returns (uint256)',
    'function decimals() view returns (uint8)'
  ];

  let provider, signer, swordContract, walletAddress;
  let battling=false, monsterHoard=0;

  const swordInput=document.getElementById('sword-count');
  const chanceBadge=document.getElementById('chance-badge');
  swordInput.addEventListener('input',()=>{
    const v=parseInt(swordInput.value)||0;
    if(v>=100){chanceBadge.textContent='Player wins 98%';chanceBadge.className='chance-badge good';}
    else{chanceBadge.textContent='Monster wins 98%';chanceBadge.className='chance-badge bad';}
  });

  async function connectWallet(){
    if(!window.ethereum){document.getElementById('no-metamask').style.display='block';return;}
    const btn=document.getElementById('connect-btn');
    btn.disabled=true; btn.textContent='Connecting...';
    try {
      await window.ethereum.request({method:'eth_requestAccounts'});
      try {
        await window.ethereum.request({method:'wallet_switchEthereumChain',params:[{chainId:SEPOLIA_CHAIN_ID}]});
      } catch(sw){
        if(sw.code===4902){
          await window.ethereum.request({method:'wallet_addEthereumChain',params:[{
            chainId:SEPOLIA_CHAIN_ID,chainName:'Sepolia',
            nativeCurrency:{name:'SepoliaETH',symbol:'ETH',decimals:18},
            rpcUrls:['https://rpc.sepolia.org'],
            blockExplorerUrls:['https://sepolia.etherscan.io']
          }]});
        }
      }
      provider=new ethers.BrowserProvider(window.ethereum);
      signer=await provider.getSigner();
      walletAddress=await signer.getAddress();
      swordContract=new ethers.Contract(SWORD_ADDRESS,ERC20_ABI,signer);
      await refreshBalance();
      document.getElementById('wallet-addr').textContent=walletAddress.slice(0,6)+'...'+walletAddress.slice(-4);
      document.getElementById('pre-connect').style.display='none';
      document.getElementById('arena').style.display='block';
    } catch(e){
      btn.disabled=false; btn.textContent='Connect MetaMask';
      alert(e.message?.slice(0,120)||'Connection failed');
    }
  }

  async function refreshBalance(){
    const dec=await swordContract.decimals();
    const raw=await swordContract.balanceOf(walletAddress);
    const bal=Math.floor(Number(ethers.formatUnits(raw,dec)));
    document.getElementById('sword-bal').textContent=bal.toLocaleString();
  }

  function disconnect(){
    signer=null;provider=null;swordContract=null;walletAddress=null;
    document.getElementById('arena').style.display='none';
    document.getElementById('pre-connect').style.display='block';
    const btn=document.getElementById('connect-btn');
    btn.disabled=false;btn.textContent='Connect MetaMask';
  }

  function log(text,cls=''){
    const el=document.getElementById('battle-log');
    const p=document.createElement('p');p.className='log-line '+(cls||'sys');p.textContent=text;
    el.appendChild(p);el.scrollTop=el.scrollHeight;
  }
  function logLink(text,url){
    const el=document.getElementById('battle-log');
    const a=document.createElement('a');a.className='tx-link';a.textContent=text;
    a.href=url;a.target='_blank';el.appendChild(a);el.scrollTop=el.scrollHeight;
  }
  function clearLog(){document.getElementById('battle-log').innerHTML='';}
  function setHP(who,pct){
    const fill=document.getElementById('hp-'+who+'-fill');
    const txt=document.getElementById('hp-'+who+'-text');
    const hp=Math.max(0,Math.round(pct));
    fill.style.width=hp+'%';fill.className='hp-fill'+(hp<30?' low':'');
    txt.textContent=hp+' HP';
  }
  function shake(id){const e=document.getElementById(id);e.classList.remove('shaking');void e.offsetWidth;e.classList.add('shaking');setTimeout(()=>e.classList.remove('shaking'),400);}
  function glow(id){const e=document.getElementById(id);e.classList.remove('glowing');void e.offsetWidth;e.classList.add('glowing');setTimeout(()=>e.classList.remove('glowing'),600);}
  function sleep(ms){return new Promise(r=>setTimeout(r,ms));}
  function updateHoard(n){
    monsterHoard+=n;
    const el=document.getElementById('hoard-count');
    el.textContent=monsterHoard.toLocaleString()+' ⚔';
    el.classList.remove('pulse');void el.offsetWidth;el.classList.add('pulse');
  }

  async function startBattle(){
    if(battling)return;
    if(!signer){alert('Connect your wallet first!');return;}
    const swords=parseInt(swordInput.value)||0;
    if(swords<1){alert('Enter at least 1 SWORD.');return;}

    battling=true;
    const btn=document.getElementById('fight-btn');
    btn.disabled=true;
    const banner=document.getElementById('result-banner');
    banner.style.display='none';banner.className='result-banner';

    clearLog();
    setHP('player',100);setHP('monster',100);
    document.getElementById('sprite-player').textContent='🧝';
    document.getElementById('sprite-monster').textContent='🐉';

    const strongEnough=swords>=100;
    const playerWins=strongEnough?(Math.random()<0.98):(Math.random()<0.02);

    log(`⚔ Entering arena with ${swords.toLocaleString()} SWORD${swords===1?'':'s'}!`,'sys');
    await sleep(600);
    log(strongEnough?'The champion radiates power — the monster hesitates...':'Too few swords — the monster snarls in contempt...','sys');
    await sleep(700);

    log('📜 Confirm the transfer in MetaMask...','sys');
    let txHash=null;
    try {
      const dec=await swordContract.decimals();
      const amount=ethers.parseUnits(String(swords),dec);
      const tx=await swordContract.transfer(MONSTER_ADDRESS,amount);
      txHash=tx.hash;
      log('✦ Transaction submitted — confirming on-chain...','gold');
      logLink('View on Etherscan ↗',`https://sepolia.etherscan.io/tx/${txHash}`);
      await tx.wait();
      log('✦ Confirmed!','gold');
      await refreshBalance();
    } catch(e){
      log('✦ Transfer failed: '+(e?.reason||e?.message?.slice(0,80)||'cancelled'),'lose');
      btn.disabled=false;btn.textContent='⚔ Fight Again';battling=false;return;
    }
    await sleep(400);

    let pHP=100,mHP=100;
    const rounds=4+Math.floor(Math.random()*3);
    for(let r=0;r<rounds;r++){
      await sleep(550);
      if(playerWins){
        const pd=15+Math.floor(Math.random()*20),md=3+Math.floor(Math.random()*8);
        mHP=Math.max(5,mHP-pd);pHP=Math.max(10,pHP-md);
        setHP('monster',mHP);setHP('player',pHP);
        shake('sprite-monster');await sleep(200);shake('sprite-player');
        log(`Round ${r+1}: Your blade strikes for ${pd} damage! Wyrm claws back for ${md}.`,'atk');
      } else {
        const pd=15+Math.floor(Math.random()*22),md=2+Math.floor(Math.random()*5);
        pHP=Math.max(5,pHP-pd);mHP=Math.max(10,mHP-md);
        setHP('player',pHP);setHP('monster',mHP);
        shake('sprite-player');await sleep(200);shake('sprite-monster');
        log(`Round ${r+1}: The wyrm unleashes ${pd} fire damage! You scratch back for ${md}.`,'def');
      }
      if(r===rounds-1){
        await sleep(700);
        if(playerWins){setHP('monster',0);glow('sprite-player');log('FINAL STRIKE! The dragon falls!','win');}
        else{setHP('player',0);glow('sprite-monster');log('The wyrm roars — your champion falls...','lose');}
      }
    }

    await sleep(800);
    if(playerWins){
      log('✦ Victory! 0.001 Sepolia ETH reward awaits (deploy BattleArena contract).','gold');
      document.getElementById('sprite-player').textContent='👑';
      document.getElementById('sprite-monster').textContent='💀';
      banner.className='result-banner victory';
      document.getElementById('result-title').textContent='⚔ Victory!';
      document.getElementById('result-sub').textContent='Your swords vanquished the wyrm. Glory is yours.';
    } else {
      log('✦ Defeat. The monster claimed your swords.','lose');
      updateHoard(swords);
      document.getElementById('sprite-player').textContent='💀';
      document.getElementById('sprite-monster').textContent='🐉';
      banner.className='result-banner defeat';
      document.getElementById('result-title').textContent='☠ Defeat';
      document.getElementById('result-sub').textContent='Return with 100+ SWORD tokens to fight with honor.';
    }
    if(txHash){
      const a=document.createElement('a');a.className='tx-link';
      a.textContent='View confirmed transaction ↗';
      a.href=`https://sepolia.etherscan.io/tx/${txHash}`;a.target='_blank';
      banner.appendChild(document.createElement('br'));banner.appendChild(a);
    }
    banner.style.display='block';
    btn.disabled=false;btn.textContent='⚔ Fight Again';battling=false;
  }

  window.addEventListener('load',async()=>{
    if(window.ethereum){
      const accounts=await window.ethereum.request({method:'eth_accounts'});
      if(accounts.length)connectWallet();
      window.ethereum.on('accountsChanged',()=>location.reload());
      window.ethereum.on('chainChanged',()=>location.reload());
    }
  });
</script>
</body>
</html>
